    "# =========================\n",
    "# 1) Daten laden\n",
    "# =========================\n",
    "data = pd.read_csv(\"eeg_Simon_3.csv\")\n",
    "\n",
    "t = data[\"timestamp\"].to_numpy()\n",
    "x = data[\"ch1\"].to_numpy(dtype=float)\n",
    "\n",
    "dt = np.median(np.diff(t))\n",
    "\n",
    "# Falls timestamp in Sekunden:\n",
    "fs = 1.0 / dt\n",
    "\n",
    "# Falls timestamp in Millisekunden, stattdessen:\n",
    "# fs = 1000.0 / dt\n",
    "\n",
    "print(f\"dt = {dt}\")\n",
    "print(f\"Sampling rate: {fs:.2f} Hz\")\n",
    "\n",
    "# =========================\n",
    "# 2) Filter\n",
    "# =========================\n",
    "# Notch 50 Hz\n",
    "b_notch, a_notch = signal.iirnotch(50, Q=30, fs=fs)\n",
    "\n",
    "# Hochpass und Tiefpass als SOS\n",
    "sos_hp = signal.butter(4, 1, btype=\"highpass\", fs=fs, output=\"sos\")\n",
    "sos_lp = signal.butter(4, 35, btype=\"lowpass\", fs=fs, output=\"sos\")\n",
    "\n",
    "# Filtern\n",
    "x_filt = signal.filtfilt(b_notch, a_notch, x)\n",
    "x_filt = signal.sosfiltfilt(sos_hp, x_filt)\n",
    "x_filt = signal.sosfiltfilt(sos_lp, x_filt)\n",
    "x_filt = x_filt[2000:]\n",
    "\n",
    "# =========================\n",
    "# 3) Epoching\n",
    "# =========================\n",
    "def epoch_signal(x, fs, epoch_sec=2.0):\n",
    "    L = int(epoch_sec * fs)\n",
    "    n = len(x) // L\n",
    "    return x[:n * L].reshape(n, L)\n",
    "\n",
    "epochs = epoch_signal(x_filt, fs)\n",
    "\n",
    "# =========================\n",
    "# 4) Artefakt-Filter\n",
    "# =========================\n",
    "def mad(a):\n",
    "    return np.median(np.abs(a - np.median(a))) + 1e-12\n",
    "\n",
    "ptp = np.ptp(epochs, axis=1)\n",
    "rms = np.sqrt(np.mean(epochs**2, axis=1))\n",
    "\n",
    "good = (\n",
    "    (ptp < np.median(ptp) + 6 * mad(ptp)) &\n",
    "    (rms < np.median(rms) + 6 * mad(rms))\n",
    ")\n",
    "\n",
    "epochs_good = epochs[good]\n",
    "\n",
    "print(f\"Kept {len(epochs_good)} / {len(epochs)} epochs\")\n",
    "\n",
    "if len(epochs_good) == 0:\n",
    "    raise ValueError(\"Keine guten Epochen übrig. Prüfe Filter oder Schwellen.\")\n",
    "\n",
    "# =========================\n",
    "# 5) PSD + Bandpower\n",
    "# =========================\n",
    "def bandpower(freqs, psd, fmin, fmax):\n",
    "    idx = (freqs >= fmin) & (freqs < fmax)\n",
    "    if not np.any(idx):\n",
    "        return np.nan\n",
    "    return np.trapezoid(psd[idx], freqs[idx])\n",
    "\n",
    "bands = {\n",
    "    \"Delta\": (0.5, 4),\n",
    "    \"Theta\": (4, 8),\n",
    "    \"Alpha\": (8, 13),\n",
    "    \"Beta\":  (13, 30),\n",
    "    \"Gamma\": (30, 35),\n",
    "}\n",
    "\n",
    "bandpowers = []\n",
    "\n",
    "for ep in epochs_good:\n",
    "    nperseg = min(len(ep), int(fs * 2))\n",
    "    noverlap = min(int(fs), nperseg // 2)\n",
    "\n",
    "    f, pxx = signal.welch(\n",
    "        ep,\n",
    "        fs=fs,\n",
    "        window=\"hann\",\n",
    "        nperseg=nperseg,\n",
    "        noverlap=noverlap,\n",
    "        detrend=\"constant\",\n",
    "        scaling=\"density\"\n",
    "    )\n",
    "\n",
    "    bp = {\n",
    "        name: bandpower(f, pxx, lo, hi)\n",
    "        for name, (lo, hi) in bands.items()\n",
    "    }\n",
    "    bandpowers.append(bp)\n",
    "\n",
    "df_bp = pd.DataFrame(bandpowers)\n",
    "\n",
    "# =========================\n",
    "# 6) log-transform\n",
    "# =========================\n",
    "df_log = np.log(df_bp + 1e-12)\n",
    "\n",
    "# =========================\n",
    "# 7) Baseline\n",
    "# =========================\n",
    "n_baseline = min(10, len(df_log))\n",
    "baseline = df_log.iloc[:n_baseline]\n",
    "\n",
    "mu = baseline.mean()\n",
    "sigma = baseline.std().replace(0, 1e-12)\n",
    "\n",
    "# =========================\n",
    "# 8) z-Scores\n",
    "# =========================\n",
    "z_scores = (df_log - mu) / sigma\n",
    "\n",
    "# optional glätten\n",
    "z_smooth = z_scores.rolling(window=5, min_periods=1).mean()\n",
    "\n",
    "print(z_smooth.head())\n",
    "\n",
    "# =========================\n",
    "# 9) Plot\n",
    "# =========================\n",
    "plt.figure(figsize=(10, 5))\n",
    "for band in bands:\n",
    "    plt.plot(z_smooth[band], label=band)\n",
    "\n",
    "plt.axhline(0, linestyle=\"--\")\n",
    "plt.title(\"EEG Band z-Scores\")\n",
    "plt.xlabel(\"Epoch\")\n",
    "plt.ylabel(\"z-score\")\n",
    "plt.legend()\n",
    "plt.grid(True)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
